# Your FPL Draft league ID
# Find it in the URL when viewing your league: draft.premierleague.com/league/LEAGUE_ID
# Or in your browser's Network tab when loading the league page
LEAGUE_ID=12345

# --- web/ only (Vite): Live tab CORS proxy ---
# Production: GitHub secret VITE_FPL_PROXY_URL
# Local dev: copy web/.env.local.example → web/.env.local (see that file)
# VITE_FPL_PROXY_URL=https://your-worker.your-subdomain.workers.dev
